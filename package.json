{
  "name": "kardex-constructora",
  "version": "0.1.0",
  "description": "Sistema de Kardex para Empresa Constructora",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "testing"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "npm run dev --workspace=@kardex/api",
    "dev:web": "npm run dev --workspace=@kardex/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "npm run test:e2e --workspace=@kardex/testing",
    "test:e2e:ui": "npm run test:e2e:ui --workspace=@kardex/testing",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "docker:up": "docker-compose up -d --wait",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:reset": "docker-compose down -v && docker-compose up -d --wait",
    "db:generate": "npm run prisma:generate --workspace=@kardex/api",
    "db:migrate": "npm run prisma:migrate --workspace=@kardex/api",
    "db:migrate:init": "npm run prisma:migrate:init --workspace=@kardex/api",
    "db:seed": "npm run prisma:seed --workspace=@kardex/api",
    "db:studio": "npm run prisma:studio --workspace=@kardex/api",
    "db:reset": "npm run prisma:reset --workspace=@kardex/api",
    "setup": "npm install && npm run docker:up && npm run db:generate && npm run db:migrate:init && npm run db:seed",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.4.0",
    "@commitlint/types": "^19.0.0",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=11.0.0"
  }
}
