# API Environment Variables
# Copy to .env for local development

# Database (PostgreSQL)
DATABASE_URL=postgresql://kardex_user:kardex_password@localhost:5432/kardex_db

# Redis (for queues + websocket adapter)
REDIS_URL=redis://localhost:6379

# Server
NODE_ENV=development
API_PORT=4000
API_HOST=localhost

# JWT (generate secrets with: openssl rand -base64 32)
JWT_SECRET=change-me-in-production-use-a-strong-random-value
JWT_REFRESH_SECRET=change-me-in-production-different-from-jwt-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# First Admin Bootstrap (Optional)
# If defined, seed creates first Admin automatically
ADMIN_DOC_TYPE=DNI
ADMIN_DOC_NUMBER=12345678
ADMIN_PASSWORD=CambiarEn_PrimerLogin_2026
ADMIN_FIRST_NAME=Administrador
ADMIN_LAST_NAME=Principal
ADMIN_EMAIL=admin@empresa.com

# Logging
LOG_LEVEL=debug
