// Prisma Schema - Kardex API
// Documentation: https://www.prisma.io/docs/concepts/components/prisma-schema
//
// Minimal schema for Fase 1C.
// Additional models (Warehouse, Item, Stock, Movement, etc.) will be added in later phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum DocumentType {
  DNI
  CE
  PASAPORTE
}

// ============================================================================
// USER & AUTH
// ============================================================================

model User {
  id                 String       @id @default(cuid())
  documentType       DocumentType
  documentNumber     String
  passwordHash       String
  firstName          String
  lastName           String
  email              String?      @unique
  phone              String?
  roleId             String
  role               Role         @relation(fields: [roleId], references: [id])
  active             Boolean      @default(true)
  mustChangePassword Boolean      @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  @@unique([documentType, documentNumber, deletedAt])
  @@index([deletedAt])
  @@index([roleId])
  @@map("users")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  systemRole  Boolean          @default(false)
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  resource    String
  action      String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())

  @@unique([resource, action])
  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  assignedAt   DateTime   @default(now())

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================================
// SYSTEM SETTINGS (Feature Flags, Setup Status, etc.)
// ============================================================================

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([key])
  @@map("system_settings")
}
