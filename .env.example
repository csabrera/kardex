# Kardex Environment Variables (Root Level)
# Copy to .env.local for local development

# Database
DATABASE_URL=postgresql://kardex_user:kardex_password@localhost:5432/kardex_db

# Redis
REDIS_URL=redis://localhost:6379

# Node Environment
NODE_ENV=development

# API (apps/api)
API_PORT=4000
API_HOST=localhost

# Frontend (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:4000

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_SECRET=your-secret-key-here-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-here-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Optional: Admin bootstrap (Seed)
# If defined, first deploy will create this admin user automatically
ADMIN_DOC_TYPE=DNI
ADMIN_DOC_NUMBER=12345678
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FIRST_NAME=Administrador
ADMIN_LAST_NAME=Principal

# Logging
LOG_LEVEL=debug
