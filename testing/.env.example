# Testing environment
# Copy to .env.local for custom setup

# URLs (defaults work if you run npm run dev for both apps)
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000

# Admin credentials used by globalSetup to log in and save storageState.
# Defaults match the seed.ts admin in apps/api/.env.
# IMPORTANT: this admin MUST have already completed the mustChangePassword flow
# (log in once manually and change password, then put the new one here),
# otherwise globalSetup will abort with a clear error.
E2E_ADMIN_DOC_TYPE=DNI
E2E_ADMIN_DOC_NUMBER=12345678
E2E_ADMIN_PASSWORD=CambiarEn_PrimerLogin_2026

# Dedicated test database (only used by db.helper.ts for optional truncation).
# For the default E2E tests we reuse the dev DB, so this is only needed for
# isolated integration tests that truncate.
DATABASE_URL=postgresql://kardex_user:kardex_password@localhost:5432/kardex_db

# CI flag (set automatically by GitHub Actions)
# CI=true
