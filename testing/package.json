{
  "name": "@kardex/testing",
  "version": "0.1.0",
  "description": "E2E tests for Kardex (Playwright)",
  "private": true,
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint \"{e2e,fixtures,helpers}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "install:browsers": "playwright install --with-deps",
    "db:reset": "cd ../apps/api && npm run prisma:reset"
  },
  "dependencies": {
    "@kardex/types": "*",
    "@kardex/utils": "*"
  },
  "devDependencies": {
    "@kardex/eslint-config": "*",
    "@kardex/tsconfig": "*",
    "@playwright/test": "^1.46.1",
    "@prisma/client": "^5.19.0",
    "@types/node": "^20.14.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "form-data": "^4.0.0",
    "prisma": "^5.19.0",
    "typescript": "^5.5.0"
  }
}
